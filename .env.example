# Environment placeholders for dhakal-improved
# Copy this to .env and fill values as needed

# JWT secret for POS auth
JWT_SECRET=dev_jwt_secret

# Enable scheduled expiry check (set to 1 to enable when running server)
ENABLE_EXPIRY_CRON=0
EXPIRY_DAYS=30
# Interval in ms for expiry checks (default daily)
EXPIRY_INTERVAL_MS=86400000
# If you prefer cron scheduling (node-cron), set USE_NODE_CRON=1 and optionally CRON_EXPR
USE_NODE_CRON=0
CRON_EXPR=0 2 * * *

# Email (SMTP) settings for expiry alert emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=supersecret
FROM_EMAIL=you@example.com
# Comma-separated list of recipients for expiry alerts
EXPIRY_ALERT_EMAILS=admin@example.com

# Database / Knex/other envs as needed
DATABASE_URL=file:./dev.sqlite3

